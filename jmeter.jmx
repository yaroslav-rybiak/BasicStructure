        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Login to SmartClient" enabled="true">
          <stringProp name="WebDriverSampler.script">//jmeter.bat -n -t C:\Users\rybiaky\Downloads\SmartClient.jmx -l C:\Users\rybiaky\Downloads\result.jtl -Jlogin=somelogin -Jpassword=somepassword

import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
import org.apache.jmeter.threads.JMeterContextService;
import org.apache.jmeter.threads.JMeterVariables;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

//Login to SmartClient
JMeterVariables vars = JMeterContextService.getContext().getVariables();
String login = vars.getObject(&quot;login&quot;);
String password = vars.getObject(&quot;password&quot;);
String url = vars.getObject(&quot;url&quot;);
WDS.browser.get(url);
WDS.sampleResult.sampleStart();
if(WDS.browser.getTitle().equals(&quot;ISSO Global Login&quot;)) {
	RemoteWebElement loginField = WDS.browser.findElement(By.name(&quot;USER&quot;));
	RemoteWebElement passField = WDS.browser.findElement(By.name(&quot;PASSWORD&quot;));
	RemoteWebElement loginButton = WDS.browser.findElement(By.xpath(&quot;//input[@type=&apos;submit&apos;]&quot;));
	loginField.sendKeys(new String[] { login });
	passField.sendKeys(new String[] { password });
	loginButton.click();
	wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//h2[text()=&apos;Clients&apos;]&quot;)));
}
WDS.sampleResult.sampleEnd();</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">java</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Complete first screen (Select Product Group)" enabled="true">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

WDS.sampleResult.sampleStart();
//Click &quot;New Account&quot; link
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//a[text()=&apos;New Account&apos;]&quot;)));
WDS.browser.findElement(By.xpath(&quot;//a[text()=&apos;New Account&apos;]&quot;)).click();

//Complete first screen, click &quot;Next&quot;
//wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//div[@id=&apos;NewAccWizard&apos;]&quot;)));
wait.until(ExpectedConditions.presenceOfElementLocated(By.id(&quot;apac&quot;)));
WDS.browser.findElement(By.id(&quot;apac&quot;)).click();
WDS.browser.findElement(By.id(&quot;eq_cash&quot;)).click();
WDS.browser.findElement(By.id(&quot;asianEq&quot;)).click();
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//button[contains(text(), &apos;Next&apos;)]&quot;)));
WDS.browser.findElement(By.xpath(&quot;//button[contains(text(), &apos;Next&apos;)]&quot;)).click();
WDS.sampleResult.sampleEnd();
</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">java</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Complete second screen (Client)" enabled="true">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

WDS.sampleResult.sampleStart();
//Complete second screen, click &quot;Next&quot;
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//h3[contains(text(), &apos;Wizard: Client&apos;)]&quot;)));
WDS.browser.findElement(By.name(&quot;gcce_link&quot;)).sendKeys(new String[] { &quot;1231238&quot; });
WDS.browser.findElement(By.name(&quot;client_name&quot;)).sendKeys(new String[] { &quot;TestSmart-GC1&quot; });
WDS.browser.findElement(By.xpath(&quot;//button[contains(text(), &apos;Next&apos;)]&quot;)).click();
WDS.sampleResult.sampleEnd();
</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">java</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Complete third screen (Account Details)" enabled="true">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

WDS.sampleResult.sampleStart();

//Complete third screen, click &quot;Next&quot;
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//select[@id=&apos;accountType&apos;]&quot;)));
wait.until(ExpectedConditions.elementToBeClickable(By.name(&quot;accDetailsGlce&quot;)));
WDS.browser.findElement(By.name(&quot;accDetailsGlce&quot;)).sendKeys(new String[] { &quot;1231238&quot; });
WDS.browser.findElement(By.xpath(&quot;//select[@id=&apos;accountType&apos;]&quot;)).sendKeys(new String[] { &quot;Client&quot; });
WDS.browser.findElement(By.xpath(&quot;//select[@id=&apos;accountTypeDetail&apos;]&quot;)).sendKeys(new String[] { &quot;Allocation&quot; });
WDS.browser.findElement(By.xpath(&quot;//select[@id=&apos;relType&apos;]&quot;)).sendKeys(new String[] { &quot;Principal&quot; });

//wait.until(ExpectedConditions.elementToBeClickable(By.name(&quot;name&quot;)));
WDS.browser.findElement(By.name(&quot;name&quot;)).sendKeys(new String[] { &quot;TestSmart-GL1&quot; });
WDS.browser.findElement(By.name(&quot;shortName&quot;)).sendKeys(new String[] { &quot;Smart&quot; });
WDS.browser.findElement(By.xpath(&quot;//button[contains(text(), &apos;Next&apos;)]&quot;)).click();
WDS.sampleResult.sampleEnd();
</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">java</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Complete fourth screen (Contracting Entities)" enabled="true">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

WDS.sampleResult.sampleStart();
//Complete fourth screen, click &quot;Next&quot;
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//h3[contains(text(), &apos;Wizard: Contracting Entities&apos;)]&quot;)));
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//td[text()=&apos;4001&apos;]/parent::tr/td/button&quot;)));
WDS.browser.findElement(By.xpath(&quot;//td[text()=&apos;4001&apos;]/parent::tr/td/button&quot;)).click();
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//button[contains(text(), &apos;Next&apos;)]&quot;)));
WDS.browser.findElement(By.xpath(&quot;//button[contains(text(), &apos;Next&apos;)]&quot;)).click();
WDS.sampleResult.sampleEnd();
</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">java</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Save case" enabled="true">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
import org.apache.jmeter.threads.JMeterContextService;
import org.apache.jmeter.threads.JMeterVariables;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

WDS.sampleResult.sampleStart();
//Save case
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//button[contains(text(), &apos;Save&apos;)]&quot;)));
WDS.browser.findElement(By.xpath(&quot;//button[contains(text(), &apos;Save&apos;)]&quot;)).click();
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//h3[contains(text(), &apos;Confirmation&apos;)]&quot;)));
WDS.browser.findElement(By.xpath(&quot;//button[text()=&apos;OK&apos;]&quot;)).click();

wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//div[@class=&apos;toast-message&apos;]&quot;)));
System.out.println(
WDS.browser.findElement(By.xpath(&quot;//div[@class=&apos;toast-message&apos;]&quot;)).getText()
);

//try variable
JMeterVariables vars = JMeterContextService.getContext().getVariables();
vars.put(&quot;test&quot;, WDS.browser.findElement(By.xpath(&quot;//div[@class=&apos;toast-message&apos;]&quot;)).getText());
WDS.sampleResult.sampleEnd();</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">java</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Close notifications" enabled="true">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
import org.apache.jmeter.threads.JMeterContextService;
import org.apache.jmeter.threads.JMeterVariables;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

WDS.sampleResult.sampleStart();
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//h3[contains(text(), &apos;Notification&apos;)]&quot;)));
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//h3[contains(text(), &apos;Notification&apos;)]/preceding-sibling::button&quot;)));
WDS.browser.findElement(By.xpath(&quot;//h3[contains(text(), &apos;Notification&apos;)]/preceding-sibling::button&quot;)).click();
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//div[@id=&apos;NewAccWizard&apos;]/div/button&quot;)));
WDS.browser.findElement(By.xpath(&quot;//div[@id=&apos;NewAccWizard&apos;]/div/button&quot;)).click();
WDS.sampleResult.sampleEnd();
</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">java</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
