        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Click save" enabled="true">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

WDS.sampleResult.sampleStart();
RemoteWebElement saveButton = WDS.browser.findElement(By.xpath(&quot;//button[text()=&apos;Save&apos;]&quot;));
saveButton.click();
wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//h3[text()=&apos;Confirmation&apos;]&quot;)));
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//div[@class=&apos;modal-footer&apos;]/button[text()=&apos;OK&apos;]&quot;)));
WDS.browser.findElement(By.xpath(&quot;//div[@class=&apos;modal-footer&apos;]/button[text()=&apos;OK&apos;]&quot;)).click();

wait.until(ExpectedConditions.presenceOfElementLocated(By.xpath(&quot;//h3[contains(text(), &apos;Notification&apos;)]&quot;)));
wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//h3[contains(text(), &apos;Notification&apos;)]/preceding-sibling::button&quot;)));
WDS.browser.findElement(By.xpath(&quot;//h3[contains(text(), &apos;Notification&apos;)]/preceding-sibling::button&quot;)).click();
WDS.sampleResult.sampleEnd();

wait.until(ExpectedConditions.elementToBeClickable(By.xpath(&quot;//a[text()=&apos;Client&apos;]&quot;)));
RemoteWebElement clientLink = WDS.browser.findElement(By.xpath(&quot;//a[text()=&apos;Client&apos;]&quot;));
clientLink.click();</stringProp>
