        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Enter ID, click search" enabled="true">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.remote.RemoteWebElement;
import org.apache.jmeter.threads.JMeterContextService;
import org.apache.jmeter.threads.JMeterVariables;
import java.util.ArrayList;
import java.util.Random;
WebDriverWait wait = new WebDriverWait(WDS.browser, 30);

//pick random account from the list
JMeterVariables vars = JMeterContextService.getContext().getVariables();
String account1 = vars.getObject(&quot;account1&quot;);
String account2 = vars.getObject(&quot;account2&quot;);
String account3 = vars.getObject(&quot;account3&quot;);
String account4 = vars.getObject(&quot;account4&quot;);
String account5 = vars.getObject(&quot;account5&quot;);
ArrayList accounts;
accounts = new ArrayList();
        accounts.add(account1);
        accounts.add(account2);
        accounts.add(account3);
        accounts.add(account4);
        accounts.add(account5);
        Random r = new Random();
        int i = r.nextInt(accounts.size());
        String account = accounts.get(i);
        
WDS.sampleResult.sampleStart();
//Enter the GL number in search field
RemoteWebElement searchField = WDS.browser.findElement(By.id(&quot;searchValueField&quot;));
searchField.clear();
searchField.sendKeys(new String[] {account});
RemoteWebElement searchButton = WDS.browser.findElement(By.xpath(&quot;//span[contains(@class, &apos;glyphicon-search&apos;) and contains(@class ,&apos;searchIcon&apos;)]&quot;));

// Click on search icon and start recording the time for this request
searchButton.click();
WDS.sampleResult.sampleEnd();
</stringProp>
